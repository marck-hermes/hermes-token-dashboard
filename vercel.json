{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/data/(.*)", "destination": "/data/$1" },
    { "source": "/str-flow-chart.html", "destination": "/str-flow-chart.html" },
    { "source": "/backup-flow.html", "destination": "/backup-flow.html" },
    { "source": "/llm-comparison.html", "destination": "/llm-comparison.html" },
    { "source": "/openrouter-usage.html", "destination": "/openrouter-usage.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" }
      ]
    }
  ]
}